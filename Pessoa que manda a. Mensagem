<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Enviar Chamado</title>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <style>
        body { background: #0f172a; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .card { background: #1e293b; padding: 30px; border-radius: 20px; width: 350px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); text-align: center; }
        textarea { 
            width: 100%; height: 120px; padding: 15px; background: #0b0f1a; border: 1px solid #334155; 
            color: white; border-radius: 12px; margin-bottom: 20px; resize: none; font-size: 1rem; box-sizing: border-box;
        }
        button { 
            background: #ef4444; color: white; border: none; padding: 18px; width: 100%; 
            border-radius: 12px; cursor: pointer; font-weight: bold; font-size: 1.1rem; transition: 0.2s;
        }
        button:hover { background: #dc2626; }
        #status { margin-top: 15px; font-size: 0.85rem; font-weight: bold; }
    </style>
</head>
<body>

<div class="card">
    <h2 style="margin-top:0; color:#f87171;">🚨 Ajuda P2P</h2>
    <textarea id="textoMsg" placeholder="Digite sua mensagem de ajuda aqui..."></textarea>
    <button onclick="disparar()">ENVIAR AGORA</button>
    <div id="status"></div>
</div>

<script>
    const peer = new Peer();
    const ID_DO_MONITOR = 'chamado-urgente-p2p';

    function disparar() {
        const msg = document.getElementById('textoMsg').value || "Preciso de ajuda urgente no sistema!";
        const status = document.getElementById('status');
        
        status.innerText = "Conectando ao seu monitor...";
        status.style.color = "#94a3b8";

        const conn = peer.connect(ID_DO_MONITOR);

        conn.on('open', () => {
            conn.send(msg);
            status.innerText = "✅ ENVIADO COM SUCESSO!";
            status.style.color = "#22c55e";
            document.getElementById('textoMsg').value = "";
        });

        conn.on('error', () => {
            status.innerText = "❌ ERRO: Seu monitor está offline!";
            status.style.color = "#ef4444";
        });
    }
</script>
</body>
</html>
